# Primary provider profile
LLM_PROVIDER=moonshot
LLM_API_KEY=your_api_key_here
LLM_MODEL=kimi-k2-5
# Optional:
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_JSON_MODE=prompt

# Candidate profile for `npm run check:llm:ab`
# The candidate profile inherits missing values from the primary LLM profile,
# so for same-provider model A/B you often only need to override the model.
# LLM_CANDIDATE_PROVIDER=openai
# LLM_CANDIDATE_API_KEY=your_openai_api_key_here
# LLM_CANDIDATE_MODEL=gpt-4.1-mini
# LLM_CANDIDATE_BASE_URL=https://api.openai.com/v1
# LLM_CANDIDATE_JSON_MODE=native

# Legacy Moonshot aliases still work
# KIMI_API_KEY=your_kimi_api_key_here
# KIMI_MODEL=kimi-k2-5
# KIMI_BASE_URL=https://api.moonshot.cn/v1
