{
  "name": "md-to-html-slides",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "md-to-html-slides": "./scripts/build.mjs"
  },
  "scripts": {
    "core:compile": "tsc -p tsconfig.json --pretty false",
    "core:studio": "npm run core:compile && node ./dist-ts/scripts/studio-server.js",
    "core:studio:legacy": "node ./scripts/studio-server.mjs",
    "core:skills": "node ./scripts/build.mjs skills",
    "core:themes": "node ./scripts/build.mjs themes",

    "test:fallback": "npm run core:compile && node ./dist-ts/scripts/check-agent.js",
    "test:skills": "npm run core:compile && node ./dist-ts/scripts/check-skill.js",
    "test:render-deck": "npm run core:compile && node ./dist-ts/scripts/check-render-deck.js",
    "test:cli": "npm run example:validate-skill && npm run example:validate && npm run core:themes && npm run example:render-deck && npm run example:render && npm run example:build && npm run example:build:editorial && npm run example:build:launch && npm run example:preview",
    "test:llm": "npm run core:compile && node ./dist-ts/scripts/check-llm.js",
    "test:llm:ab": "npm run core:compile && node ./dist-ts/scripts/check-llm.js --ab",
    "test": "npm run test:fallback && npm run test:skills && npm run test:render-deck && npm run test:cli",

    "example:validate": "node ./scripts/build.mjs validate ./fixtures/course/clean/openclaw-intro.md",
    "example:validate-skill": "node ./scripts/build.mjs validate-skill ./skills/founder-pitch.json",
    "example:validate-skill-dir": "node ./scripts/build.mjs validate-skill-dir ./skills",
    "example:plan": "node ./scripts/build.mjs plan ./fixtures/course/clean/openclaw-intro.md --skill general",
    "example:plan:skill-file": "node ./scripts/build.mjs plan ./fixtures/pitch/clean/product-pitch.md --skill-file ./skills/founder-pitch.json",
    "example:expand": "node ./scripts/build.mjs expand ./fixtures/course/clean/openclaw-intro.md --skill general",
    "example:render-deck": "node ./scripts/build.mjs expand ./fixtures/course/clean/openclaw-intro.md --skill general -o ./.tmp/examples/01-agent-expanded.json && node ./scripts/build.mjs render-deck ./.tmp/examples/01-agent-expanded.json -o ./.tmp/examples/01-agent-render-deck.json",
    "example:render": "node ./scripts/build.mjs render ./.tmp/examples/01-agent-render-deck.json -o ./.tmp/examples/01-agent-rendered-from-deck.html --theme dark-card",
    "example:build": "node ./scripts/build.mjs build ./fixtures/course/clean/openclaw-intro.md -o ./.tmp/examples/01-agent.html --theme dark-card",
    "example:build:editorial": "node ./scripts/build.mjs build ./fixtures/course/clean/openclaw-intro.md -o ./.tmp/examples/01-agent-editorial.html --theme editorial-light",
    "example:build:launch": "node ./scripts/build.mjs build ./fixtures/pitch/clean/product-pitch.md -o ./.tmp/examples/01-launch-tech.html --theme tech-launch --skill pitch-tech-launch",
    "example:preview": "node ./scripts/build.mjs preview ./fixtures/course/clean/openclaw-intro.md --theme dark-card",

    "studio": "npm run core:studio",
    "skills": "npm run core:skills",
    "themes": "npm run core:themes",
    "check": "npm run test"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
