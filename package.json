{
  "name": "md-to-html-slides",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "md-to-html-slides": "./scripts/build.mjs"
  },
  "scripts": {
    "build:example": "node ./scripts/build.mjs build ./slides-src/openclaw/01-agent.md -o ./examples/01-agent.html --theme dark-card",
    "build:example:editorial": "node ./scripts/build.mjs build ./slides-src/openclaw/01-agent.md -o ./examples/01-agent-editorial.html --theme editorial-light",
    "preview:example": "node ./scripts/build.mjs preview ./slides-src/openclaw/01-agent.md --theme dark-card",
    "themes": "node ./scripts/build.mjs themes",
    "validate:example": "node ./scripts/build.mjs validate ./slides-src/openclaw/01-agent.md",
    "check": "npm run validate:example && npm run themes && npm run build:example && npm run build:example:editorial && npm run preview:example"
  }
}
